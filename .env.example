# Ollama model used across planner, creator, executor, and optimizer
OLLAMA_MODEL=llama3.1:8b

# CampaignX API key required for cohort fetch, send, and report retrieval
CAMPAIGNX_API_KEY=your_campaignx_api_key_here

# Optional: enable verbose Ollama client logging
CAMPAIGNX_DEBUG_LLM=false

# Optional: enable redacted executor/debug logging
CAMPAIGNX_DEBUG_EXECUTION=false

# Optional: how the CTA is rendered in outbound email bodies
# Allowed values: raw_url, labeled_plain, html_anchor
CAMPAIGNX_CTA_MODE=raw_url

# Optional: allow local cohort fixture fallback for explicit demo/offline runs only
CAMPAIGNX_ALLOW_LOCAL_COHORT_FALLBACK=false

# Optional: allow optimizer retry sends without per-retry human approval
CAMPAIGNX_OPTIMIZER_AUTO_APPROVE_SENDS=false
