# Ollama model used across planner, creator, executor, and optimizer
OLLAMA_MODEL=llama3.1:8b

# CampaignX API key required for cohort fetch, send, and report retrieval
CAMPAIGNX_API_KEY=Ar9UukyW8qQKJVPejhA0O9fTIZoMvMgfu_ZGnrSO0Pk

# Optional: enable verbose Ollama client logging
CAMPAIGNX_DEBUG_LLM=false

# Optional: how the CTA is rendered in outbound email bodies
# Allowed values: raw_url, labeled_plain, html_anchor
CAMPAIGNX_CTA_MODE=raw_url
